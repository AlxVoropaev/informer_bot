# ============================================================================
# Informer bot — environment configuration
# ----------------------------------------------------------------------------
# Copy this file to data/.env and fill in the REQUIRED section. Everything
# below the REQUIRED block has sensible defaults — uncomment only what you
# want to override.
# ============================================================================


# ----------------------------------------------------------------------------
# REQUIRED
# ----------------------------------------------------------------------------

# Telegram API credentials (https://my.telegram.org → API development tools)
TELEGRAM_API_ID=
TELEGRAM_API_HASH=

# Bot token from @BotFather
TELEGRAM_BOT_TOKEN=

# Your Telegram user id (numeric). The bot DMs only this user.
OWNER_ID=

# Required when CHAT_PROVIDER=anthropic (the default).
# Get a key at https://console.anthropic.com/
ANTHROPIC_API_KEY=


# ----------------------------------------------------------------------------
# LOGGING
# ----------------------------------------------------------------------------

# DEBUG | INFO | WARNING | ERROR
# LOG_LEVEL=INFO


# ----------------------------------------------------------------------------
# STORAGE PATHS
# ----------------------------------------------------------------------------

# SQLite database path
# DB_PATH=data/informer.db

# Telethon session file path (no extension)
# SESSION_PATH=data/informer


# ----------------------------------------------------------------------------
# CHAT PROVIDER (LLM used for summaries)
# ----------------------------------------------------------------------------
# anthropic — Claude via Anthropic API (needs ANTHROPIC_API_KEY)
# ollama    — local Ollama server (OpenAI-compatible endpoint)
# remote    — delegate to processor_bot over a private Telegram group
# CHAT_PROVIDER=anthropic

# Used when CHAT_PROVIDER=ollama
# OLLAMA_BASE_URL=http://localhost:11434/v1
# OLLAMA_CHAT_MODEL=qwen3.5:4b


# ----------------------------------------------------------------------------
# EMBEDDING PROVIDER (used for deduplication)
# ----------------------------------------------------------------------------
# auto    — pick openai if OPENAI_API_KEY is set, else none
# openai  — text-embedding-3-small @ 512 dims (paid API)
# ollama  — local Ollama embedding model
# remote  — delegate to processor_bot
# none    — disable dedup; owner is DM'd once at startup
# EMBEDDING_PROVIDER=auto

# Required when EMBEDDING_PROVIDER resolves to openai
OPENAI_API_KEY=

# Used when EMBEDDING_PROVIDER=ollama
# OLLAMA_EMBEDDING_MODEL=qwen3-embedding:4b


# ----------------------------------------------------------------------------
# REMOTE PROVIDER (processor_bot via private bus group)
# ----------------------------------------------------------------------------
# Required when CHAT_PROVIDER=remote or EMBEDDING_PROVIDER=remote.
# See docs/internals/processor-bot.md for the full setup.

# Negative integer id of the private Telegram group used as the bus
# BUS_GROUP_ID=

# Numeric user id of processor_bot
# PROCESSOR_BOT_USER_ID=

# Seconds to wait for a remote reply before falling back
# PROCESSOR_TIMEOUT_SECONDS=60

# Ping interval used to track processor health
# HEALTH_CHECK_INTERVAL_SECONDS=60

# Used when the remote processor is unreachable.
# CHAT_PROVIDER_FALLBACK: anthropic | ollama
# EMBEDDING_PROVIDER_FALLBACK: openai | ollama | none
# CHAT_PROVIDER_FALLBACK=anthropic
# EMBEDDING_PROVIDER_FALLBACK=openai


# ----------------------------------------------------------------------------
# DEDUP TUNING
# ----------------------------------------------------------------------------

# Cosine similarity threshold for "same story" (0.0–1.0)
# DEDUP_THRESHOLD=0.85

# Lookback window for dedup comparisons
# DEDUP_WINDOW_HOURS=48

# How far back to replay missed posts on restart (per channel, capped)
# CATCH_UP_WINDOW_HOURS=48


# ----------------------------------------------------------------------------
# MINI APP (experimental — branch miniapp-test)
# ----------------------------------------------------------------------------
# When MINIAPP_URL is set, the bot starts an in-process aiohttp server on
# WEBAPP_HOST:WEBAPP_PORT, exposes /app, and registers a burger-menu launcher.
#
# Default compose.yaml uses Caddy as a reverse proxy with automatic Let's
# Encrypt HTTPS. Point a domain (or free DuckDNS subdomain) at this host's
# public IP, then set BOTH MINIAPP_DOMAIN and MINIAPP_URL to that domain.
# Caddy reads MINIAPP_DOMAIN; the bot reads MINIAPP_URL.
#
# Prerequisites: ports 80 and 443 reachable from the public internet.
# Note: if port 443 is occupied (e.g. by an MTProto VPN), Caddy serves HTTPS
# on 8443 instead — include `:8443` in MINIAPP_URL. Port 80 still has to be
# free for Let's Encrypt's HTTP-01 challenge.

# MINIAPP_DOMAIN=miniapp.yourdomain.com
# MINIAPP_URL=https://miniapp.yourdomain.com:8443
# WEBAPP_HOST=0.0.0.0
# WEBAPP_PORT=8085


# ============================================================================
# processor_bot — only needed when running the sidecar bot in this same env
# ----------------------------------------------------------------------------
# processor_bot is a separate service that handles remote LLM/embedding
# requests on a private GPU host. See docs/internals/processor-bot.md.
# Skip this whole block unless you are running processor_bot here.
# ============================================================================

# Bot token for processor_bot — distinct from TELEGRAM_BOT_TOKEN
# PROCESSOR_BOT_TOKEN=

# Numeric Telegram user id of the informer bot (sender filter on the bus)
# INFORMER_BOT_USER_ID=

# BUS_GROUP_ID is shared with the REMOTE PROVIDER section above.
# SESSION_PATH on processor_bot defaults to data/processor (override if needed).
