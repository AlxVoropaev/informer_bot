TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TELEGRAM_BOT_TOKEN=
ANTHROPIC_API_KEY=
# OPENAI_API_KEY is optional. Used only when EMBEDDING_PROVIDER=openai (or
# unset, in which case it auto-selects openai if a key is present, else none).
OPENAI_API_KEY=
OWNER_ID=
LOG_LEVEL=INFO
# Embedding provider for dedup: auto (default), openai, local, or none.
# - auto:   openai if OPENAI_API_KEY is set, else none
# - openai: text-embedding-3-small @ 512 dims (paid API)
# - local:  via fastembed; default model intfloat/multilingual-e5-large
#           (~2.2GB, 1024 dims, top multilingual quality). Needs ~3GB RAM on
#           CPU; on tight VPS hosts use openai or none instead. The cache
#           lives in data/fastembed_cache so it survives container restarts.
# - none:   disable dedup entirely; owner DM'd once at startup
# EMBEDDING_PROVIDER=auto
# LOCAL_EMBEDDING_MODEL=intfloat/multilingual-e5-large
# LOCAL_EMBEDDING_DEVICE=cpu     # set to "cuda" if you have a GPU and the
#                                # fastembed-gpu package installed
# Optional dedup tuning:
# DEDUP_THRESHOLD=0.85
# DEDUP_WINDOW_HOURS=48
# How far back to replay missed posts on restart (per channel, capped):
# CATCH_UP_WINDOW_HOURS=48
# Mini App (experimental, branch miniapp-test). When MINIAPP_URL is set, the
# bot starts an in-process aiohttp server on WEBAPP_HOST:WEBAPP_PORT, exposes
# /app, and registers a burger-menu launcher. Telegram requires HTTPS — for
# local testing, point a tunnel (cloudflared / ngrok) at WEBAPP_PORT.
# MINIAPP_URL=
# WEBAPP_HOST=0.0.0.0
# WEBAPP_PORT=8080
# Auto-discovery: instead of hard-coding MINIAPP_URL, point at a file the
# cloudflared sidecar writes its log to — the bot will extract the latest
# https://*.trycloudflare.com URL from it on startup. Already wired by
# compose.yaml (the cloudflared service uses /shared/cloudflared.log via a
# named volume). Ignored when MINIAPP_URL is set explicitly.
# MINIAPP_URL_FILE=/cloudflared/cloudflared.log
