TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TELEGRAM_BOT_TOKEN=
ANTHROPIC_API_KEY=
# OPENAI_API_KEY is optional. Used only when EMBEDDING_PROVIDER=openai (or
# unset, in which case it auto-selects openai if a key is present, else none).
OPENAI_API_KEY=
OWNER_ID=
LOG_LEVEL=INFO
# Embedding provider for dedup: auto (default), openai, local, or none.
# - auto:   openai if OPENAI_API_KEY is set, else none
# - openai: text-embedding-3-small @ 512 dims (paid API)
# - local:  on-CPU via fastembed (no API cost; ~470MB model download on first run)
# - none:   disable dedup entirely; owner DM'd once at startup
# EMBEDDING_PROVIDER=auto
# LOCAL_EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
# Optional dedup tuning:
# DEDUP_THRESHOLD=0.85
# DEDUP_WINDOW_HOURS=48
